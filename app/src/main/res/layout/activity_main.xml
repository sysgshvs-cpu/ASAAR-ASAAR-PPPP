<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#1A1A1A">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PUBG Unlocker"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="بانتظار منح الصلاحيات"
        android:textColor="#FF9900"
        android:textSize="16sp"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/permissionButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="منح الصلاحيات للهاتف واجهة 11 فما فوق"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF4444"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/unlockButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="فتح السكنات"
        android:textColor="#FFFFFF"
        android:backgroundTint="#44FF44"
        android:layout_marginBottom="16dp"
        android:enabled="false"/>

    <Button
        android:id="@+id/resetButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="استعادة الأصلي"
        android:textColor="#FFFFFF"
        android:backgroundTint="#444444"
        android:layout_marginBottom="16dp"
        android:enabled="false"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="دليل عمل كل ما يحدث لحسابك وجهازك"
        android:textColor="#FF4444"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="16dp"
        android:background="#330000"/>

</LinearLayout>
